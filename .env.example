# Production env template for Vercel
# ─────────────────────────────────────────────────────────────────────────
# 1. 运行时:Neon 连接池(-pooler 后缀) — 所有 Prisma 查询走这个
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.DOMAIN/DBNAME?sslmode=require"

# 2. 仅 Vercel 构建期使用 — Neon direct endpoint(去掉 -pooler)
#    用于 prisma migrate deploy,避开 pgBouncer 事务模式与
#    pg_advisory_lock 的不兼容(P1002 超时)。
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST.DOMAIN/DBNAME?sslmode=require"

# 3. 32+ char random secret for JWT session signing
#    Generate: openssl rand -base64 48
SESSION_SECRET=""